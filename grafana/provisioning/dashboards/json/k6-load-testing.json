{
  "title": "k6 Load Testing",
  "uid": "k6-load-testing",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Requisições por segundo",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(k6_http_reqs_total[1m])",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Usuários virtuais ativos (VUs)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "k6_vus",
          "legendFormat": "VUs"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latência HTTP (ms)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "k6_http_req_duration_p95",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "k6_http_req_duration_p99",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Taxa de erros HTTP",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(k6_http_req_failed_total[1m])",
          "legendFormat": "erros/s"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "TTFB — tempo de espera pelo servidor (ms)",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "k6_http_req_waiting_p95",
          "legendFormat": "p95 TTFB"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Duração das iterações (ms)",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "k6_iteration_duration_p95",
          "legendFormat": "p95 iteração"
        }
      ]
    }
  ]
}
