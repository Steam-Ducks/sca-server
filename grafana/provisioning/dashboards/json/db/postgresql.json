{
  "title": "Banco de Dados",
  "uid": "postgresql",
  "schemaVersion": 38,
  "version": 6,
  "refresh": "30s",
  "graphTooltip": 1,
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Status",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 5 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "1": { "text": "Operacional", "color": "green" }, "0": { "text": "Fora do ar", "color": "red" } } }] } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "pg_up", "legendFormat": "" }]
    },
    {
      "id": 2, "type": "stat", "title": "Conexões em uso",
      "description": "Conexões processando uma consulta agora",
      "gridPos": { "x": 4, "y": 0, "w": 5, "h": 5 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 50, "color": "orange" }, { "value": 90, "color": "red" }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(pg_stat_activity_count{state='active'})", "legendFormat": "" }]
    },
    {
      "id": 3, "type": "stat", "title": "Cache hit (%)",
      "description": "Leituras respondidas pela memória sem tocar o disco. Meta: acima de 99%",
      "gridPos": { "x": 9, "y": 0, "w": 5, "h": 5 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }, { "value": 90, "color": "orange" }, { "value": 99, "color": "green" }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "100 * sum(rate(pg_stat_database_blks_hit_total[5m])) / (sum(rate(pg_stat_database_blks_hit_total[5m])) + sum(rate(pg_stat_database_blks_read_total[5m])) + 1)", "legendFormat": "" }]
    },
    {
      "id": 4, "type": "stat", "title": "Deadlocks (1 h)",
      "description": "Impasses entre operações. Qualquer valor acima de zero merece atenção",
      "gridPos": { "x": 14, "y": 0, "w": 5, "h": 5 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 1, "color": "red" }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(increase(pg_stat_database_deadlocks_total[1h]))", "legendFormat": "" }]
    },
    {
      "id": 5, "type": "stat", "title": "Aguardando liberação",
      "description": "Consultas bloqueadas esperando outra operação liberar um recurso",
      "gridPos": { "x": 19, "y": 0, "w": 5, "h": 5 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 1, "color": "orange" }, { "value": 5, "color": "red" }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(pg_stat_activity_count{wait_event_type='Lock'})", "legendFormat": "" }]
    },
    {
      "id": 6, "type": "timeseries", "title": "Conexões por estado",
      "description": "Em uso: processando · Ociosas: abertas sem consulta · Ociosas em transação: possível vazamento · Aguardando: bloqueadas",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 9 },
      "fieldConfig": {
        "defaults": { "fillOpacity": 8, "lineWidth": 2 },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Em uso" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Ociosas" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Ociosas em transação" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Aguardando liberação" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(pg_stat_activity_count{state='active'})", "legendFormat": "Em uso" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(pg_stat_activity_count{state='idle'})", "legendFormat": "Ociosas" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(pg_stat_activity_count{state='idle in transaction'})", "legendFormat": "Ociosas em transação" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(pg_stat_activity_count{wait_event_type='Lock'})", "legendFormat": "Aguardando liberação" }
      ]
    },
    {
      "id": 7, "type": "timeseries", "title": "Operações de dados / s",
      "description": "Queda brusca em leituras junto com aumento de carga indica gargalo no banco",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 9 },
      "fieldConfig": {
        "defaults": { "unit": "ops", "fillOpacity": 8, "lineWidth": 2 },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Lidas/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Inseridas/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Alteradas/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Excluídas/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(pg_stat_database_tup_returned_total[1m]))", "legendFormat": "Lidas/s" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(pg_stat_database_tup_inserted_total[1m]))", "legendFormat": "Inseridas/s" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(pg_stat_database_tup_updated_total[1m]))", "legendFormat": "Alteradas/s" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(pg_stat_database_tup_deleted_total[1m]))", "legendFormat": "Excluídas/s" }
      ]
    }
  ]
}
