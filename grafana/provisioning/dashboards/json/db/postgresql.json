{
  "title": "Banco de Dados",
  "uid": "postgresql",
  "schemaVersion": 38,
  "version": 4,
  "refresh": "30s",
  "graphTooltip": 1,
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 100, "type": "row", "title": "Agora",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }, "collapsed": false
    },
    {
      "id": 1, "type": "stat", "title": "Status",
      "description": "O banco de dados está respondendo normalmente",
      "gridPos": { "x": 0, "y": 1, "w": 3, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "1": { "text": "Operacional", "color": "green" }, "0": { "text": "Fora do ar", "color": "red" } } }] } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "pg_up", "legendFormat": "" }]
    },
    {
      "id": 2, "type": "stat", "title": "Conexões em uso",
      "description": "Conexões com o banco que estão processando uma consulta agora",
      "gridPos": { "x": 3, "y": 1, "w": 3, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 50, "color": "orange" }, { "value": 90, "color": "red" }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(pg_stat_activity_count{state='active'})", "legendFormat": "" }]
    },
    {
      "id": 3, "type": "stat", "title": "Transações confirmadas/s",
      "description": "Quantas transações são salvas com sucesso por segundo",
      "gridPos": { "x": 6, "y": 1, "w": 3, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(pg_stat_database_xact_commit_total[1m]))", "legendFormat": "" }]
    },
    {
      "id": 4, "type": "stat", "title": "Dados em cache (%)",
      "description": "Percentual de leituras respondidas pela memória sem ir ao disco. Meta: acima de 99%",
      "gridPos": { "x": 9, "y": 1, "w": 3, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }, { "value": 90, "color": "orange" }, { "value": 99, "color": "green" }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "100 * sum(rate(pg_stat_database_blks_hit_total[5m])) / (sum(rate(pg_stat_database_blks_hit_total[5m])) + sum(rate(pg_stat_database_blks_read_total[5m])) + 1)", "legendFormat": "" }]
    },
    {
      "id": 5, "type": "stat", "title": "Tamanho do banco",
      "description": "Espaço total ocupado pelo banco de dados em disco",
      "gridPos": { "x": 12, "y": 1, "w": 3, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(pg_database_size_bytes)", "legendFormat": "" }]
    },
    {
      "id": 6, "type": "stat", "title": "Transações canceladas/s",
      "description": "Transações desfeitas por segundo. Alto = possível problema de concorrência ou erros na aplicação",
      "gridPos": { "x": 15, "y": 1, "w": 3, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 1, "color": "orange" }, { "value": 10, "color": "red" }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(pg_stat_database_xact_rollback_total[1m]))", "legendFormat": "" }]
    },
    {
      "id": 7, "type": "stat", "title": "Bloqueios mútuos (1h)",
      "description": "Situações em que duas operações ficaram esperando uma pela outra. Qualquer valor acima de zero merece atenção",
      "gridPos": { "x": 18, "y": 1, "w": 3, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 1, "color": "red" }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(increase(pg_stat_database_deadlocks_total[1h]))", "legendFormat": "" }]
    },
    {
      "id": 8, "type": "stat", "title": "Consultas aguardando liberação",
      "description": "Consultas paradas esperando outra operação terminar de usar um recurso",
      "gridPos": { "x": 21, "y": 1, "w": 3, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 1, "color": "orange" }, { "value": 5, "color": "red" }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(pg_stat_activity_count{wait_event_type='Lock'})", "legendFormat": "" }]
    },
    {
      "id": 101, "type": "row", "title": "Conexões e transações",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }, "collapsed": false
    },
    {
      "id": 9, "type": "timeseries", "title": "Conexões por estado",
      "description": "Em uso: processando agora. Ociosas: abertas mas sem consulta. Ociosas em transação: dentro de transação aberta (pode ser sinal de vazamento). Aguardando: paradas esperando outra operação",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(pg_stat_activity_count{state='active'})", "legendFormat": "Em uso" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(pg_stat_activity_count{state='idle'})", "legendFormat": "Ociosas" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(pg_stat_activity_count{state='idle in transaction'})", "legendFormat": "Ociosas em transação" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(pg_stat_activity_count{wait_event_type='Lock'})", "legendFormat": "Aguardando liberação" }
      ]
    },
    {
      "id": 10, "type": "timeseries", "title": "Transações por segundo",
      "description": "Confirmadas: salvas com sucesso. Canceladas: desfeitas por erro ou conflito",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(pg_stat_database_xact_commit_total[1m]))", "legendFormat": "Confirmadas/s" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(pg_stat_database_xact_rollback_total[1m]))", "legendFormat": "Canceladas/s" }
      ]
    },
    {
      "id": 102, "type": "row", "title": "Cache e bloqueios",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 }, "collapsed": false
    },
    {
      "id": 11, "type": "timeseries", "title": "Aproveitamento de cache por banco (%)",
      "description": "Quanto das leituras foi respondido pela memória sem ir ao disco. Abaixo de 90% indica leitura excessiva de disco",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "100 * rate(pg_stat_database_blks_hit_total[5m]) / (rate(pg_stat_database_blks_hit_total[5m]) + rate(pg_stat_database_blks_read_total[5m]) + 1)", "legendFormat": "{{datname}}" }
      ]
    },
    {
      "id": 12, "type": "timeseries", "title": "Bloqueios ativos por tipo",
      "description": "Bloqueios são normais durante operações simultâneas. Valores muito altos indicam contenção — operações esperando umas pelas outras",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (mode) (pg_locks_count)", "legendFormat": "{{mode}}" }
      ]
    },
    {
      "id": 103, "type": "row", "title": "Operações de dados",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 }, "collapsed": false
    },
    {
      "id": 13, "type": "timeseries", "title": "Linhas lidas, inseridas, alteradas e excluídas por segundo",
      "description": "Volume de operações de dados por segundo. Lidas inclui resultados de SELECT. As demais refletem inserções, atualizações e exclusões",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 8 },
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(pg_stat_database_tup_returned_total[1m]))", "legendFormat": "Lidas/s" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(pg_stat_database_tup_inserted_total[1m]))", "legendFormat": "Inseridas/s" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(pg_stat_database_tup_updated_total[1m]))", "legendFormat": "Alteradas/s" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(pg_stat_database_tup_deleted_total[1m]))", "legendFormat": "Excluídas/s" }
      ]
    },
    {
      "id": 104, "type": "row", "title": "Varreduras e problemas",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 1 }, "collapsed": false
    },
    {
      "id": 14, "type": "timeseries", "title": "Varreduras por tabela — completa vs. por índice",
      "description": "Varredura completa: lê a tabela inteira (lento em tabelas grandes). Por índice: vai direto ao registro (rápido). Muitas varreduras completas em tabelas grandes = falta de índice",
      "gridPos": { "x": 0, "y": 33, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "topk(10, rate(pg_stat_user_tables_seq_scan_total[5m]))", "legendFormat": "completa: {{relname}}" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "topk(10, rate(pg_stat_user_tables_idx_scan_total[5m]))", "legendFormat": "por índice: {{relname}}" }
      ]
    },
    {
      "id": 15, "type": "timeseries", "title": "Bloqueios mútuos por segundo",
      "description": "Situações de impasse entre operações, resolvidas pelo banco. Qualquer valor acima de zero em produção merece investigação imediata",
      "gridPos": { "x": 12, "y": 33, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "table", "placement": "right" }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 0.001, "color": "red" }] } } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(pg_stat_database_deadlocks_total[5m])", "legendFormat": "Bloqueios mútuos/s — {{datname}}" }
      ]
    }
  ]
}
