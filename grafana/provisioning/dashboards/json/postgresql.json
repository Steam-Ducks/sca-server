{
  "title": "PostgreSQL",
  "uid": "postgresql",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Status",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pg_up",
          "legendFormat": "up"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ]
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Conexões ativas",
      "gridPos": { "x": 4, "y": 0, "w": 10, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pg_stat_activity_count{state='active'}",
          "legendFormat": "ativas"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pg_stat_activity_count{state='idle'}",
          "legendFormat": "idle"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pg_stat_activity_count{wait_event_type='Lock'}",
          "legendFormat": "lock wait"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Transações por segundo",
      "gridPos": { "x": 14, "y": 0, "w": 10, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(pg_stat_database_xact_commit_total[1m])",
          "legendFormat": "commits/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(pg_stat_database_xact_rollback_total[1m])",
          "legendFormat": "rollbacks/s"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Cache hit ratio (%)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * rate(pg_stat_database_blks_hit_total[5m]) / (rate(pg_stat_database_blks_hit_total[5m]) + rate(pg_stat_database_blks_read_total[5m]) + 1)",
          "legendFormat": "hit ratio"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Locks",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pg_locks_count",
          "legendFormat": "{{mode}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Linhas retornadas/inseridas/atualizadas/deletadas por segundo",
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(pg_stat_database_tup_returned_total[1m])",
          "legendFormat": "returned/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(pg_stat_database_tup_inserted_total[1m])",
          "legendFormat": "inserted/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(pg_stat_database_tup_updated_total[1m])",
          "legendFormat": "updated/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(pg_stat_database_tup_deleted_total[1m])",
          "legendFormat": "deleted/s"
        }
      ]
    }
  ]
}
