{
  "title": "k6 — Monitoramento em Tempo Real",
  "uid": "k6-load-testing",
  "schemaVersion": 38,
  "version": 5,
  "refresh": "10s",
  "graphTooltip": 1,
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "scenario",
        "label": "Cenário",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(k6_http_reqs_total, scenario)",
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 100, "type": "row", "title": "Neste momento",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }, "collapsed": false
    },
    {
      "id": 1, "type": "stat", "title": "Usuários simultâneos",
      "description": "Quantos usuários virtuais estão ativos agora no teste",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 500, "color": "orange" }, { "value": 5000, "color": "red" }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "k6_vus{scenario=~\"$scenario\"}", "legendFormat": "" }]
    },
    {
      "id": 2, "type": "stat", "title": "Requisições por segundo",
      "description": "Quantas requisições HTTP o sistema está processando agora",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(k6_http_reqs_total{scenario=~\"$scenario\"}[1m])", "legendFormat": "" }]
    },
    {
      "id": 3, "type": "stat", "title": "Taxa de erro",
      "description": "Percentual de requisições com erro agora. Meta: abaixo de 1%",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 0.01, "color": "orange" }, { "value": 0.05, "color": "red" }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(k6_http_req_failed_total{scenario=~\"$scenario\"}[1m]) / rate(k6_http_reqs_total{scenario=~\"$scenario\"}[1m])", "legendFormat": "" }]
    },
    {
      "id": 4, "type": "stat", "title": "Tempo de resposta — 95% das req.",
      "description": "95% das requisições responderam em menos deste tempo. Meta: abaixo de 2s",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 1000, "color": "orange" }, { "value": 5000, "color": "red" }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "k6_http_req_duration_p95{scenario=~\"$scenario\"}", "legendFormat": "" }]
    },
    {
      "id": 5, "type": "stat", "title": "Tempo de resposta — 99% das req.",
      "description": "99% das requisições responderam em menos deste tempo",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 2000, "color": "orange" }, { "value": 10000, "color": "red" }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "k6_http_req_duration_p99{scenario=~\"$scenario\"}", "legendFormat": "" }]
    },
    {
      "id": 6, "type": "stat", "title": "Ciclos completos",
      "description": "Quantas vezes cada usuário virtual completou o fluxo inteiro de requisições",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "k6_iterations_total{scenario=~\"$scenario\"}", "legendFormat": "" }]
    },
    {
      "id": 101, "type": "row", "title": "Visão geral",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 }, "collapsed": false
    },
    {
      "id": 7, "type": "timeseries", "title": "Usuários simultâneos e requisições por segundo",
      "description": "Barras azuis: usuários ativos (eixo direito). Linha verde: requisições por segundo (eixo esquerdo)",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "fieldConfig": { "overrides": [{ "matcher": { "id": "byName", "options": "Usuários ativos" }, "properties": [{ "id": "custom.axisPlacement", "value": "right" }] }] },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(k6_http_reqs_total{scenario=~\"$scenario\"}[1m])", "legendFormat": "Requisições/s" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "k6_vus{scenario=~\"$scenario\"}", "legendFormat": "Usuários ativos" }
      ]
    },
    {
      "id": 8, "type": "timeseries", "title": "Tempo de resposta ao longo do teste",
      "description": "Mediana: metade das req. foram mais rápidas. 95%: só 5% demoraram mais. 99%: só 1% demoraram mais",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "k6_http_req_duration_p50{scenario=~\"$scenario\"}", "legendFormat": "Mediana (50%)" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "k6_http_req_duration_p95{scenario=~\"$scenario\"}", "legendFormat": "Lento (95%)" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "k6_http_req_duration_p99{scenario=~\"$scenario\"}", "legendFormat": "Muito lento (99%)" }
      ]
    },
    {
      "id": 102, "type": "row", "title": "Por endpoint",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 }, "collapsed": false
    },
    {
      "id": 9, "type": "timeseries", "title": "Tempo de resposta por endpoint — 95% das req.",
      "description": "Tempo que 95% das requisições de cada endpoint levaram. Endpoints com linha mais alta são os gargalos",
      "gridPos": { "x": 0, "y": 15, "w": 24, "h": 10 },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "k6_http_req_duration_p95{scenario=~\"$scenario\", name!=\"\"}", "legendFormat": "{{name}}" }
      ]
    },
    {
      "id": 10, "type": "timeseries", "title": "Requisições por segundo por endpoint",
      "description": "Volume de tráfego em cada endpoint durante o teste",
      "gridPos": { "x": 0, "y": 25, "w": 12, "h": 9 },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(k6_http_reqs_total{scenario=~\"$scenario\", name!=\"\"}[1m])", "legendFormat": "{{name}}" }
      ]
    },
    {
      "id": 11, "type": "timeseries", "title": "Erros por endpoint",
      "description": "Requisições com erro por endpoint. Qualquer linha acima de zero merece atenção",
      "gridPos": { "x": 12, "y": 25, "w": 12, "h": 9 },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(k6_http_req_failed_total{scenario=~\"$scenario\", name!=\"\"}[1m])", "legendFormat": "{{name}}" }
      ]
    },
    {
      "id": 12, "type": "timeseries", "title": "Tempo de espera pelo servidor por endpoint",
      "description": "Tempo que o servidor levou para começar a responder (exclui rede). Valor alto = servidor sobrecarregado",
      "gridPos": { "x": 0, "y": 34, "w": 24, "h": 9 },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "k6_http_req_waiting_p95{scenario=~\"$scenario\", name!=\"\"}", "legendFormat": "{{name}}" }
      ]
    },
    {
      "id": 103, "type": "row", "title": "Saúde geral",
      "gridPos": { "x": 0, "y": 43, "w": 24, "h": 1 }, "collapsed": false
    },
    {
      "id": 13, "type": "timeseries", "title": "Duração de cada ciclo completo",
      "description": "Tempo para um usuário virtual completar todas as requisições do fluxo, incluindo pausas entre chamadas",
      "gridPos": { "x": 0, "y": 44, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "k6_iteration_duration_p95{scenario=~\"$scenario\"}", "legendFormat": "95% dos ciclos" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "k6_iteration_duration_p99{scenario=~\"$scenario\"}", "legendFormat": "99% dos ciclos" }
      ]
    },
    {
      "id": 14, "type": "timeseries", "title": "Dados trafegados por segundo",
      "description": "Volume de dados recebidos e enviados entre o k6 e o servidor durante o teste",
      "gridPos": { "x": 12, "y": 44, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(k6_data_received_total{scenario=~\"$scenario\"}[1m])", "legendFormat": "Recebido/s" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(k6_data_sent_total{scenario=~\"$scenario\"}[1m])", "legendFormat": "Enviado/s" }
      ]
    }
  ]
}
