{
  "title": "k6 — Tempo Real",
  "uid": "k6-load-testing",
  "schemaVersion": 38,
  "version": 7,
  "refresh": "10s",
  "graphTooltip": 1,
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "scenario",
        "label": "Cenário",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(k6_http_reqs_total, scenario)",
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Usuários ativos",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "unit": "short" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "k6_vus{scenario=~\"$scenario\"}", "legendFormat": "" }]
    },
    {
      "id": 2, "type": "stat", "title": "Requisições / s",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 5 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "green" } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(k6_http_reqs_total{scenario=~\"$scenario\"}[1m])", "legendFormat": "" }]
    },
    {
      "id": 3, "type": "stat", "title": "Taxa de erro",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 5 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 0.01, "color": "orange" }, { "value": 0.05, "color": "red" }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(k6_http_req_failed_total{scenario=~\"$scenario\"}[1m]) / rate(k6_http_reqs_total{scenario=~\"$scenario\"}[1m])", "legendFormat": "" }]
    },
    {
      "id": 4, "type": "stat", "title": "Latência — p95",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 5 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 1000, "color": "orange" }, { "value": 5000, "color": "red" }] } } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "k6_http_req_duration_p95{scenario=~\"$scenario\"}", "legendFormat": "" }]
    },
    {
      "id": 5, "type": "timeseries", "title": "Usuários e requisições",
      "description": "Carga aplicada (usuários, eixo direito) vs throughput real (req/s, eixo esquerdo)",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 9 },
      "fieldConfig": {
        "defaults": { "fillOpacity": 8, "lineWidth": 2 },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Usuários ativos" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } },
              { "id": "unit", "value": "short" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Requisições/s" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } },
              { "id": "unit", "value": "reqps" }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(k6_http_reqs_total{scenario=~\"$scenario\"}[1m])", "legendFormat": "Requisições/s" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "k6_vus{scenario=~\"$scenario\"}", "legendFormat": "Usuários ativos" }
      ]
    },
    {
      "id": 6, "type": "timeseries", "title": "Latência ao longo do tempo",
      "description": "Subida das linhas indica degradação de performance sob carga",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 9 },
      "fieldConfig": {
        "defaults": { "unit": "ms", "fillOpacity": 8, "lineWidth": 2 },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Mediana (p50)" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Lento (p95)" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "k6_http_req_duration_p50{scenario=~\"$scenario\"}", "legendFormat": "Mediana (p50)" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "k6_http_req_duration_p95{scenario=~\"$scenario\"}", "legendFormat": "Lento (p95)" }
      ]
    },
    {
      "id": 7, "type": "timeseries", "title": "Endpoints mais lentos — p95",
      "description": "Endpoints com linha mais alta são os gargalos. Crescimento junto com VUs indica ausência de cache ou consulta lenta",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 10 },
      "fieldConfig": { "defaults": { "unit": "ms", "fillOpacity": 6, "lineWidth": 2 } },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "k6_http_req_duration_p95{scenario=~\"$scenario\", name!=\"\"}", "legendFormat": "{{name}}" }
      ]
    }
  ]
}
