{
  "id": null,
  "uid": "sca-app",
  "title": "SCA — Aplicação",
  "tags": ["sca", "app"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "env",
        "label": "Ambiente",
        "type": "custom",
        "query": "sca_prod,sca_staging",
        "current": { "selected": true, "text": "prod", "value": "sca_prod" },
        "options": [
          { "selected": true,  "text": "prod",    "value": "sca_prod" },
          { "selected": false, "text": "staging", "value": "sca_staging" }
        ],
        "hide": 0,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Requests por segundo",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "rate(django_http_requests_total_by_method_total{job=\"$env\"}[5m])",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Latência p95 (ms)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "histogram_quantile(0.95, rate(django_http_requests_latency_seconds_bucket{job=\"$env\"}[5m])) * 1000",
          "legendFormat": "p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Taxa de erro (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "rate(django_http_responses_total_by_status_total{job=\"$env\",status=~\"5..\"}[5m]) / rate(django_http_responses_total_by_status_total{job=\"$env\"}[5m]) * 100",
          "legendFormat": "erros 5xx %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Queries ao banco por segundo",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "rate(django_db_execute_total{job=\"$env\"}[5m])",
          "legendFormat": "{{vendor}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Cache hit rate (%)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 8, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "rate(django_cache_hits_total{job=\"$env\"}[5m]) / (rate(django_cache_hits_total{job=\"$env\"}[5m]) + rate(django_cache_misses_total{job=\"$env\"}[5m])) * 100",
          "legendFormat": "hit rate %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Respostas por status code",
      "type": "piechart",
      "gridPos": { "x": 8, "y": 16, "w": 8, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "sum by (status) (rate(django_http_responses_total_by_status_total{job=\"$env\"}[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Uptime (últimas 24h)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 16, "w": 8, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
          "expr": "avg_over_time(up{job=\"$env\"}[24h]) * 100",
          "legendFormat": "uptime %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 99 },
              { "color": "green", "value": 99.9 }
            ]
          }
        }
      }
    }
  ]
}
