# =============================================================================
# .env.staging.example — Template de configuração para STAGING
#
# Copie para .env no servidor de staging e preencha os valores reais.
# NUNCA comite credenciais reais. Use este arquivo apenas como referência.
#
# Diferenças em relação ao dev:
#   - DEBUG=False (igual à produção)
#   - Banco real do DigitalOcean (cluster separado ou database diferente)
#   - SEED_ENABLED=true (dados de teste são permitidos)
#   - ALLOWED_HOSTS aponta para o domínio de staging
# =============================================================================

# ─── Geral ───────────────────────────────────────────────────────────────────
DEBUG=False
SECRET_KEY=${SECRET_KEY_STAGING}
ALLOWED_HOSTS=staging.seu-dominio.com,localhost

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://staging-frontend.seu-dominio.com

# ─── Banco de dados (DigitalOcean Managed PostgreSQL — cluster de staging) ───
# Use um cluster/database separado de produção para não contaminar dados reais
DB_NAME=${DB_NAME_STAGING}
DB_USER=${DB_USER_STAGING}
DB_PASSWORD=${DB_PASSWORD_STAGING}
DB_HOST=${DB_HOST_STAGING}
DB_PORT=25060
DB_SSL_MODE=require

# ─── Seed ────────────────────────────────────────────────────────────────────
# Permite rodar: python manage.py seed_db
# Não definir em produção
SEED_ENABLED=true

# ─── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=${GRAFANA_PASSWORD_STAGING}
GRAFANA_ROOT_URL=http://staging-ip:3000
