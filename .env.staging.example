# =============================================================================
# .env.staging.example — Template de configuração para STAGING
#
# Copie para .env.staging no servidor e preencha os valores reais:
#   cp .env.staging.example .env.staging
#
# NUNCA comite .env.staging — ele já está no .gitignore.
#
# Diferenças em relação ao prod:
#   - DEBUG=False (igual à produção)
#   - Banco real do DigitalOcean (mesmo cluster, database sca_staging)
#   - Redis container interno (sca_staging_redis)
#   - CORS aponta para a porta 8001
# =============================================================================

# Configurações Gerais
DEBUG=False
SECRET_KEY=gere-com-openssl-rand-base64-32
ALLOWED_HOSTS=seu-ip-do-vps

# Banco de Dados (mesmo cluster DigitalOcean do prod, database diferente)
DB_NAME=sca_staging
DB_USER=sca_staging
DB_PASSWORD=SteamDucks
DB_HOST=seu-cluster-db-do-user-123.db.ondigitalocean.com
DB_PORT=25060

# SSL do Banco de Dados (obrigatório para DigitalOcean)
DB_SSL_MODE=require

# Redis (container interno do docker-compose.staging.yml)
REDIS_URL=redis://sca_staging_redis:6379

# CORS — frontend apontando para a porta de staging
CORS_ALLOWED_ORIGINS=http://seu-ip-do-vps:8001

# Grafana (compartilhado com prod — não precisa de instância separada)
GRAFANA_PASSWORD=sua-senha-grafana
GRAFANA_ROOT_URL=http://seu-ip-droplet:3000
